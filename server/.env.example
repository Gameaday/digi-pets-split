# Server environment variables
PORT=3000
# IMPORTANT: For production, set CORS_ORIGIN to your specific domain
# Example: CORS_ORIGIN=https://yourdomain.com
# DO NOT use * in production for security reasons
CORS_ORIGIN=*
NODE_ENV=development

# JWT Secret - CHANGE THIS IN PRODUCTION!
JWT_SECRET=digi-pets-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Database path (SQLite)
DB_PATH=./data/pets.db
